<configuration>

    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>

    <!-- ========================= -->
    <!-- CONSOLE (APP LOGS ONLY) -->
    <!-- ========================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{24} - %replace(%msg){'[\r\n]+',' | '}%replace(%mdc{correlationId}){'^(.+)$',' cid=$1'}%replace(%mdc{bookingId}){'^(.+)$',' bid=$1'}%replace(%mdc{sessionId}){'^(.+)$',' sid=$1'}%n</pattern>
        </encoder>
    </appender>

    <!-- ========================= -->
    <!-- APP FILE -->
    <!-- ========================= -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>3</maxHistory>
            <totalSizeCap>400MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <!-- Trace ids append only when set. eventTypeId/hostId had no MDC.put call sites and
                 always printed empty; externalEventId is already carried in the message bodies
                 that populate it. -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%replace(%mdc{correlationId}){'^(.+)$',' cid=$1'}%replace(%mdc{bookingId}){'^(.+)$',' bid=$1'}%replace(%mdc{sessionId}){'^(.+)$',' sid=$1'}%n</pattern>
        </encoder>
    </appender>

    <!-- ========================= -->
    <!-- BUSINESS FILE -->
    <!-- ========================= -->
    <appender name="BUSINESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/business.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/business.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>350MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{48} - %msg%replace(%mdc{correlationId}){'^(.+)$',' cid=$1'}%replace(%mdc{bookingId}){'^(.+)$',' bid=$1'}%replace(%mdc{sessionId}){'^(.+)$',' sid=$1'}%n</pattern>
        </encoder>
    </appender>

    <!-- ========================= -->
    <!-- SQL FILE -->
    <!-- ========================= -->
    <appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/sql.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/sql.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>3</maxHistory>
            <totalSizeCap>60MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ========================= -->
    <!-- ROOT LOGGER (APP ONLY) -->
    <!-- ========================= -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
    </root>

    <!-- Calendar sync re-observes every event on every sweep, so the per-event trail
         (filter_decision, apply_attempt, apply_result, upsert, recomputed) is DEBUG and the
         steady state logs one summary line per connection. To diagnose an ingest/projection
         issue, set BUNNYCAL_CALENDAR_LOG_LEVEL=DEBUG and reproduce. -->
    <logger name="io.bunnycal.calendar" level="${BUNNYCAL_CALENDAR_LOG_LEVEL:-INFO}"/>

    <logger name="io.bunnycal.ops" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="BUSINESS_FILE"/>
    </logger>

    <!-- ========================= -->
    <!-- HIBERNATE SQL (ISOLATED) -->
    <!-- ========================= -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_FILE"/>
    </logger>

    <!-- Bind parameters (optional, noisy) -->
    <logger name="org.hibernate.type.descriptor.sql" level="TRACE" additivity="false">
        <appender-ref ref="SQL_FILE"/>
    </logger>

</configuration>
