# BunnyCal API reverse proxy.
#
# Caddy terminates TLS and issues/renews certificates automatically for
# $APP_DOMAIN (api.bunnycal.io in prod) via Let's Encrypt. Only the health
# probe, API documentation, and the public API surface are proxied; everything
# else — including the actuator metrics/prometheus endpoints — returns 404
# and never reaches the application from the public internet.
{
	# Operational hardening: drop the Server banner and disable the admin API
	# (no local control socket exposed inside the container).
	servers {
		metrics
	}
	admin off
}

{$APP_DOMAIN} {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
		-X-Powered-By
	}

	handle /actuator/health* {
		reverse_proxy bunnycal-api:8080
	}

	handle /swagger-ui/* {
		reverse_proxy bunnycal-api:8080
	}

	handle /swagger-ui.html {
		reverse_proxy bunnycal-api:8080
	}

	handle /v3/api-docs* {
		reverse_proxy bunnycal-api:8080
	}

	handle /api/* {
		reverse_proxy bunnycal-api:8080
	}

	handle /auth/* {
		reverse_proxy bunnycal-api:8080
	}

	handle /oauth2/* {
		reverse_proxy bunnycal-api:8080
	}

	handle /login/oauth2/* {
		reverse_proxy bunnycal-api:8080
	}

	handle /integrations/* {
		reverse_proxy bunnycal-api:8080
	}

	handle /public/* {
		reverse_proxy bunnycal-api:8080
	}

	handle {
		respond "Not found" 404
	}
}
