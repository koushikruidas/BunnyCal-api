# =============================================================================
# BunnyCal — PRODUCTION runtime configuration TEMPLATE
# =============================================================================
# Copy to `.env` and fill in real values:  cp .env.example .env
# The real `.env` is git-ignored and is the single source of truth consumed by
# docker-compose.yaml. Every variable the app reads in the `prod` profile is
# listed here. Values marked FAIL-FAST have NO insecure default — the app will
# refuse to boot if they are missing.
# =============================================================================

# ----------------------------------------------------------------------------
# Deployment / Docker
# ----------------------------------------------------------------------------
APP_DOMAIN=api.example.com
BUNNYCAL_IMAGE=bunnycal/bunnycal-api:latest
SPRING_PROFILES_ACTIVE=prod

# ----------------------------------------------------------------------------
# Database (Postgres) — service-name networking inside the Compose network
# ----------------------------------------------------------------------------
POSTGRES_DB=bunnycal
POSTGRES_USER=bunnycal
POSTGRES_PASSWORD=change_me_strong_password
# Override only when using an external/managed database:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/bunnycal

# ----------------------------------------------------------------------------
# Redis — service-name networking inside the Compose network
# ----------------------------------------------------------------------------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Core application secrets (FAIL-FAST)
# ----------------------------------------------------------------------------
# Generate: openssl rand -base64 48 | tr '/+' '_-'
JWT_SECRET=replace_with_32_plus_char_secret
JWT_EXPIRATION=3600000
CALENDAR_WEBHOOK_SHARED_SECRET=replace_with_long_random_secret
# Generate: openssl rand -base64 32   (must decode to exactly 32 bytes)
CALENDAR_TOKEN_ENCRYPTION_KEY_BASE64=replace_with_base64_32_byte_key
CALENDAR_OAUTH_STATE_SECRET=replace_with_long_random_secret

# ----------------------------------------------------------------------------
# Email (AWS SES SMTP) — FAIL-FAST (username/password)
# ----------------------------------------------------------------------------
AWS_SES_SMTP_USERNAME=
AWS_SES_SMTP_PASSWORD=
BOOKING_NOTIFICATIONS_FROM=calendar@example.com
BOOKING_NOTIFICATIONS_CALENDAR_ORGANIZER_EMAIL=calendar@example.com
BOOKING_NOTIFICATIONS_CALENDAR_ORGANIZER_NAME=BunnyCal Calendar

# ----------------------------------------------------------------------------
# Billing (Stripe) — SaaS subscription billing (Phase 1)
# Leave BILLING_ENABLED=false to boot without Stripe (dev/test).
# ----------------------------------------------------------------------------
BILLING_ENABLED=false
BILLING_ADMIN_ENABLED=false
BILLING_NOTIFICATIONS_ENABLED=false
BILLING_TRIAL_DAYS=15
BILLING_GRACE_DAYS=3
BILLING_NOTIFICATIONS_FROM=billing@example.com
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=http://localhost:5173/dashboard/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/dashboard/billing?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/dashboard/billing

# ----------------------------------------------------------------------------
# Google OAuth / Calendar — FAIL-FAST (client id/secret)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/integrations/calendar/google/callback
GOOGLE_WEBHOOK=https://api.example.com/integrations/calendar/webhooks/google

# ----------------------------------------------------------------------------
# Microsoft OAuth / Calendar (optional — leave blank to disable)
# ----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://api.example.com/integrations/calendar/microsoft/callback
MICROSOFT_WEBHOOK=https://api.example.com/integrations/calendar/webhooks/microsoft

# ----------------------------------------------------------------------------
# Zoom OAuth / Conferencing (optional — leave blank to disable)
# ----------------------------------------------------------------------------
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=https://api.example.com/integrations/conferencing/zoom/callback
ZOOM_FRONTEND_SUCCESS_REDIRECT=https://app.example.com/dashboard/integrations
ZOOM_FRONTEND_ERROR_REDIRECT=https://app.example.com/calendar-error

# ----------------------------------------------------------------------------
# Public URLs / CORS — production domains only, no localhost.
# ----------------------------------------------------------------------------
FRONTEND_BASE_URL=https://app.example.com
APP_PUBLIC_BASE_URL=https://app.example.com
APP_SECURITY_CORS_ALLOWED_ORIGINS=https://app.example.com
APP_DOCS_PUBLIC_ENABLED=false

# ----------------------------------------------------------------------------
# Observability (disabled by default — set ENABLED=true and uncomment compose services to re-enable)
# ----------------------------------------------------------------------------
MANAGEMENT_OTLP_METRICS_EXPORT_ENABLED=false
# MANAGEMENT_OTLP_METRICS_EXPORT_URL=http://otel-collector:4318/v1/metrics
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_me_strong_password
